@model AstraTech.Routeplanner.Models.TransportRoute

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<dl class="row">
    <dt class="col-sm-3">Bezeichnung</dt>
    <dd class="col-sm-9">@Model.RouteName</dd>

    <dt class="col-sm-3">Start</dt>
    <dd class="col-sm-9">@Model.StartStation?.Name</dd>

    <dt class="col-sm-3">Ziel</dt>
    <dd class="col-sm-9">@Model.DestinationStation?.Name</dd>

    <dt class="col-sm-3">Priorität</dt>
    <dd class="col-sm-9">@Model.Priority</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Geschätzte Distanz</dt>
    <dd class="col-sm-9">@Model.EstimatedDistance</dd>

    <dt class="col-sm-3">Bemerkung</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Bearbeiten</a>
<a asp-action="Index" class="btn btn-secondary">Zurück</a>
